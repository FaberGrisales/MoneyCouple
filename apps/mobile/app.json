{
  "expo": {
    "name": "MoneyCouple",
    "slug": "moneycouple",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "moneycouple",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0E10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moneycouple.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0E0E10"
      },
      "package": "com.moneycouple.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "MoneyCouple necesita acceso a la cámara para escanear facturas." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
