{
  "name": "moneycouple",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate --filter=@moneycouple/database",
    "db:migrate": "turbo run db:migrate --filter=@moneycouple/database",
    "db:push": "turbo run db:push --filter=@moneycouple/database",
    "db:seed": "turbo run db:seed --filter=@moneycouple/database",
    "db:studio": "turbo run db:studio --filter=@moneycouple/database",
    "db:reset": "turbo run db:reset --filter=@moneycouple/database",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint-config-prettier": "^9.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "bufferutil",
      "utf-8-validate"
    ],
    "overrides": {
      "@expo/metro-runtime": "^6.1.2"
    }
  }
}
